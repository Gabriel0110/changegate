      "type": "iam_privilege_escalation",
      "title": "Principal aws_iam_role.github_actions can pass aws_iam_role.admin_execution and run lambda:UpdateFunctionCode",
      "severity": "critical",
      "confidence": "high",
      "decision": "block",
      "principal": "aws_iam_role.github_actions",
      "target": "aws_iam_role.admin_execution",
      "steps": [
        {
          "from": "aws_iam_role.github_actions",
          "to": "aws_iam_role.admin_execution",
          "action": "iam:PassRole",
          "edge_type": "can_pass_role",
          "explanation": "principal can pass a privileged or sensitive execution role"
        },
        {
          "from": "aws_iam_role.github_actions",
          "to": "aws_lambda_function.*",
          "action": "lambda:UpdateFunctionCode",
          "edge_type": "grants_permission",
          "explanation": "principal can mutate or launch compute that can use the passed role"
        }
      ],
      "evidence": [
        {
          "type": "attack_path.iam",
          "resource": "aws_iam_role.admin_execution",
          "path": "iam.policy",
          "value": [
            "aws_iam_role.github_actions",
            "lambda:UpdateFunctionCode",
            "aws_iam_role.admin_execution"
          ],
          "message": "principal has lambda:UpdateFunctionCode through aws_iam_policy.deploy"
        }
      ],
      "mitigations": [
        "Scope iam:PassRole to non-privileged execution roles and exact services.",
        "Separate compute mutation permissions from pass-role permissions."
      ],
      "references": [
        "https://changegate.dev/docs/attack-paths"
      ]
